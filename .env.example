# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key

# OpenAI (used for both LLM and TTS)
OPENAI_API_KEY=your_openai_api_key

# Vobiz
VOBIZ_AUTH_ID=your_auth_id
VOBIZ_AUTH_TOKEN=your_auth_token

# Call settings
FROM_NUMBER=+91XXXXXXXXXX
TO_NUMBER=+91XXXXXXXXXX

# Agent personality
AGENT_SYSTEM_PROMPT=You are a helpful AI assistant for Vobiz. Be concise and conversational. Keep responses under 2 sentences.

# OpenAI TTS voice: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=alloy
